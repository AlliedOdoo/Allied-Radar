# AI search and drafting only (Kimi K2.6 Free via OpenRouter)
OPENROUTER_API_KEY=
AI_MODEL=moonshotai/kimi-k2.6:free

# Supabase browser/session configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only configuration. Never expose this value to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only encryption material (base64-encoded 32 random bytes recommended)
TOKEN_ENCRYPTION_KEY=
DEVICE_TOKEN_PEPPER=

# Firebase Cloud Messaging for opaque Android handoff notifications
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Master outbound kill switch. Keep false until a provider is connected.
ENABLE_SEND_ACTIONS=false
SEND_CONFIRMATION_SECRET=

# Microsoft Graph delegated tokens
# Outlook needs Mail.Send; Teams needs ChatMessage.Send.
MICROSOFT_GRAPH_ACCESS_TOKEN=
MICROSOFT_OUTLOOK_ACCESS_TOKEN=
MICROSOFT_TEAMS_ACCESS_TOKEN=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Odoo 17/18 JSON-RPC
ODOO_URL=
ODOO_DATABASE=
ODOO_USERNAME=
ODOO_API_KEY=
ODOO_DISCUSS_MODEL=discuss.channel
# Comma-separated numeric channel IDs. Sync and sending fail closed when this is empty.
ODOO_DISCUSS_CHANNEL_IDS=
